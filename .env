# ── Configuration POC Fil Rouge v3 ───────────────────────────────────────────
# Copier ce fichier en .env.local pour les surcharges locales

# FastAPI
SSSOM_FILE=/app/data/mainframe_to_fibo.sssom.tsv
LOCAL_OUTPUT_DIR=/app/output

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jsonld-output

# MinIO console (interface web)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
